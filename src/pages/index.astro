---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroStatic from '../components/HeroStatic.astro';
import eventsData from '../data/events.json';

const description = "The chess community of IISER Mohali. Join us for tournaments, workshops, and friendly games.";
---

<BaseLayout title="Home" description={description}>
  <HeroStatic />

  <section class="bg-surface py-20 w-full relative overflow-hidden">
    <div class="max-w-[1200px] mx-auto px-4 md:px-8 grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
      <div>
        <h2 class="font-serif font-medium text-[2rem] text-parchment mb-6">A Legacy of Strategy</h2>
        <p class="font-body text-lg leading-[1.8] text-muted mb-8">
          The Desperado is more than just a chess club; it's a community of thinkers, strategists, and chess enthusiasts at IISER Mohali. We foster a culture of analytical thinking and competitive spirit through the game of chess. Whether you are a seasoned tournament player or just learning how the pieces move, there is a place for you at our boards.
        </p>
        <a href="/desperado/about" class="font-sans font-medium text-gold hover:text-gold-light transition-colors">Explore our story &rarr;</a>
      </div>
      <div class="hidden md:block h-[300px] chess-pattern border border-border rounded-lg opacity-50"></div>
    </div>
  </section>

  <section class="bg-surface py-24">
    <div class="max-w-[1200px] mx-auto px-4 md:px-8">
      <h2 class="font-serif font-medium text-[2rem] text-parchment mb-12 text-center md:text-left">Upcoming</h2>
      <div class="space-y-6 mb-12">
        {eventsData.slice(0, 3).map((event) => (
          <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8 pb-6 border-b border-border/50 group">
            <div class="font-mono text-sm text-gold-dim w-32 shrink-0">
              {new Date(event.date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }).toUpperCase()}
            </div>
            <div class="flex-grow flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-gold inline-block"></span>
              <h3 class="font-serif text-xl text-parchment group-hover:text-gold transition-colors">{event.name}</h3>
            </div>
            <div>
              <span class={`px-3 py-1 rounded-full text-[0.75rem] font-sans font-semibold tracking-widest uppercase border ${event.status === 'completed' ? 'bg-[#6b5f501f] text-dim border-border' : event.status === 'ongoing' ? 'bg-[#4a7c591f] text-[#6db88a] border-[#4a7c59]' : 'bg-[#c9a84c1f] text-gold border-gold-dim'}`}>
                {event.status}
              </span>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center md:text-left">
        <a href="/desperado/events" class="font-sans font-medium text-gold hover:text-gold-light transition-colors">See all events &rarr;</a>
      </div>
    </div>
  </section>

  <section class="bg-bg py-24 border-t border-border">
    <div class="max-w-[1200px] mx-auto px-4 md:px-8 flex flex-col items-center">
      <span class="font-sans font-semibold text-[11px] uppercase tracking-[0.15em] text-gold mb-8">Today's Puzzle</span>
      <div class="border-l-[3px] border-gold-dim pl-4 w-full max-w-[400px]">
        <iframe src="https://lichess.org/training/frame?theme=brown&bg=dark" class="w-full h-[444px] rounded-sm bg-surface-up" allowtransparency="true" frameborder="0"></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const countElements = document.querySelectorAll('[data-count-to]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const target = entry.target as HTMLElement;
        const countTo = parseInt(target.getAttribute('data-count-to') || '0', 10);
        const duration = 1500;
        const startTime = performance.now();
        
        const updateCount = (currentTime: number) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easeProgress = 1 - Math.pow(1 - progress, 3);
          
          target.innerText = Math.floor(easeProgress * countTo).toString();
          
          if (progress < 1) {
            requestAnimationFrame(updateCount);
          } else {
            target.innerText = countTo.toString();
          }
        };
        
        requestAnimationFrame(updateCount);
        observer.unobserve(target);
      }
    });
  });
  
  countElements.forEach(el => observer.observe(el));
</script>


<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
	</body>
</html>
